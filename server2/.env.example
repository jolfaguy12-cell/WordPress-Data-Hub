# =============================================================================
# Behdashtik Mirror Connector — Server 2 Environment Configuration
# Copy this file to server2/.env and fill in real values. Never commit .env.
# Generate secrets: python3 -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# ---------------------------------------------------------------------------
# Environment identity  (dev | main | prod)
# dev:  mirror_db + hub_state_db names MUST end with _dev
# main: mirror_db + hub_state_db names must NOT end with _dev
# ---------------------------------------------------------------------------
BDSK_ENV=dev

# ---------------------------------------------------------------------------
# WordPress source
# ---------------------------------------------------------------------------
BDSK_WP_BASE_URL=https://replace-with-wp-url.example.com
BDSK_API_SECRET=replace-with-long-random-hex

# ---------------------------------------------------------------------------
# Mirror DB  (WordPress data mirror — env-specific name required)
# ---------------------------------------------------------------------------
BDSK_MIRROR_DB_HOST=127.0.0.1
BDSK_MIRROR_DB_PORT=3308
BDSK_MIRROR_DB_USER=replace-with-db-user
BDSK_MIRROR_DB_PASSWORD=replace-with-db-password
BDSK_MIRROR_DB_NAME=replace-with-mirror-db-name
BDSK_MIRROR_DB_READONLY_USER=replace-with-readonly-user
BDSK_MIRROR_DB_READONLY_PASSWORD=replace-with-readonly-password

# ---------------------------------------------------------------------------
# Hub state DB  (persistent operational tables — never dropped by mirror swap)
# MUST differ from BDSK_MIRROR_DB_NAME.
# MUST end with _dev if BDSK_ENV=dev.
# ---------------------------------------------------------------------------
BDSK_HUB_STATE_DB_NAME=replace-with-hub-state-db-name

# ---------------------------------------------------------------------------
# Storage paths
# ---------------------------------------------------------------------------
BDSK_ARCHIVE_STORAGE_PATH=/replace/with/archive/path
BDSK_MEDIA_STORAGE_PATH=/replace/with/media/path

# ---------------------------------------------------------------------------
# State file path overrides (optional; default = next to pipeline.py)
# ---------------------------------------------------------------------------
# BDSK_EVENT_SYNC_STATE_PATH=/replace/with/event_sync_state.json
# BDSK_MEDIA_SYNC_STATE_PATH=/replace/with/media_sync_state.json
# BDSK_HUB_DB_PATH=/replace/with/hub.db

# ---------------------------------------------------------------------------
# Dashboard / Data API
# ---------------------------------------------------------------------------
BDSK_DASHBOARD_HOST=127.0.0.1
BDSK_DASHBOARD_PORT=8089
BDSK_HUB_SECRET_KEY=replace-with-long-random-hex
BDSK_DATA_API_KEY=replace-with-long-random-hex

# ---------------------------------------------------------------------------
# Timeouts
# ---------------------------------------------------------------------------
BDSK_REQUEST_TIMEOUT_SECONDS=60
BDSK_POLL_INTERVAL_SECONDS=5
BDSK_POLL_TIMEOUT_SECONDS=600
BDSK_FAILED_ARCHIVE_RETENTION_DAYS=14

# ---------------------------------------------------------------------------
# Media sync
# ---------------------------------------------------------------------------
BDSK_MEDIA_SYNC_ENABLED=true
BDSK_MEDIA_SYNC_CONCURRENCY=1
BDSK_MEDIA_SYNC_MAX_FILES_PER_RUN=500
BDSK_MEDIA_SYNC_MAX_MB_PER_RUN=300
BDSK_MEDIA_SYNC_MAX_FILE_SIZE_BYTES=52428800
BDSK_MEDIA_SYNC_CONNECT_TIMEOUT=10
BDSK_MEDIA_SYNC_READ_TIMEOUT=120
BDSK_MEDIA_SYNC_DOWNLOAD_RETRIES=3

# ---------------------------------------------------------------------------
# Event sync
# ---------------------------------------------------------------------------
BDSK_EVENT_SYNC_ENABLED=true
BDSK_EVENT_SYNC_BATCH_SIZE=200
BDSK_EVENT_SYNC_MAX_RETRIES=10

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
BDSK_WRITEBACK_DISABLED=true
BDSK_EXPORT_ALLOWED=true

# ---------------------------------------------------------------------------
# Production source DB — remote read-only (used by cpanel_remote_dump_import.py)
# ---------------------------------------------------------------------------
PROD_DB_HOST=replace-with-prod-mysql-host
PROD_DB_PORT=3306
PROD_DB_NAME=replace-with-prod-db-name
PROD_RO_DB_USER=replace-with-readonly-db-user
PROD_RO_DB_PASSWORD=replace-with-readonly-db-password
